# Copy this file to bench/model.env on swe_dev and edit only the values you need.
# The run scripts also source ~/.bashrc and /data/nips/shared_bench/api_config.env.

# 8.130 relay example:
MODEL_NAME=gpt-5.4
LITELLM_MODEL=openai/gpt-5.4
OPENAI_BASE_URL=http://8.130.49.170/v1
OPENAI_REASONING_EFFORT=xhigh
# OPENAI_API_KEY is normally sourced from /data/nips/shared_bench/api_config.env.

# SGLang / OpenAI-compatible local endpoint example:
# MODEL_NAME=Qwen/Qwen3-Coder-30B-A3B-Instruct
# LITELLM_MODEL=openai/Qwen/Qwen3-Coder-30B-A3B-Instruct
# OPENAI_BASE_URL=http://gpu-l-lg-cmc-h-h200-0219.host.h.pjlab.org.cn:8000/v1
# OPENAI_API_KEY=EMPTY
# OPENAI_REASONING_EFFORT=

BENCH_OUTPUT_ROOT=/mnt/shared-storage-user/mineru2-shared/zengweijun/nips2026/bench/runs
NUM_TASKS=1
NUM_TRIALS=1
MAX_CONCURRENCY=1
MAX_TOKENS=4096
MAX_INPUT_TOKENS=128000
TEMPERATURE=0.0

# Only enable this if a benchmark cannot read OPENAI_API_KEY from env and must
# receive headers in CLI JSON args. It may leak the key into ps/history/logs.
BENCH_PASS_API_KEY_IN_ARGS=0
